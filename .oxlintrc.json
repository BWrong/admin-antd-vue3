    "@typescript-eslint/no-unsafe-function-type": "error",
    "@typescript-eslint/no-floating-promises": "off",
    "unocss/order": "warn",
    "unocss/order-attributify": "warn",
    "simple-import-sort/imports": [
      "warn",
      {
        "groups": [
          [
            "^node:"
          ],
          [
            "^@?\\w"
          ],
          [
            "^"
          ],
          [
            "^\\."
          ],
          [
            "^\\u0000"
          ]
        ]
      }
    ],
    "simple-import-sort/exports": "warn"
  },
